# Local development defaults
API_PORT=3001
DATABASE_URL=file:./data/slide-maker.db
SESSION_SECRET=dev-secret-change-me

# Email (SMTP) — leave blank to skip email verification locally
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

{
  "name": "slide-maker",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:bedrock": "AI_PROVIDER=bedrock turbo dev",
    "dev:anthropic": "AI_PROVIDER=anthropic turbo dev",
    "dev:openrouter": "AI_PROVIDER=openrouter turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "db:push": "pnpm --filter api db:push",
    "db:seed": "pnpm --filter api db:seed",
    "seed:admin": "pnpm --filter api seed:admin",
    "audit:a11y": "node scripts/a11y-theme-audit.mjs",
    "start": "tsx apps/api/src/index.ts",
    "api:dev": "pnpm --filter @slide-maker/api dev",
    "api:bedrock": "AI_PROVIDER=bedrock pnpm --filter @slide-maker/api dev",
    "api:anthropic": "AI_PROVIDER=anthropic pnpm --filter @slide-maker/api dev",
    "api:openrouter": "AI_PROVIDER=openrouter pnpm --filter @slide-maker/api dev",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}

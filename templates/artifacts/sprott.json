{
  "id": "artifact-sprott",
  "name": "Sprott Attractor",
  "description": "Strange attractor from a minimal chaotic system",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<style>.back-btn,#back,#info,#ui,#mode-btn,.panel,.controls{display:none!important}</style>\n<script>if(window.self===window.top)document.documentElement.classList.add('standalone')</script>\n<style>html.standalone .back-btn,html.standalone #back,html.standalone #info,html.standalone #ui,html.standalone #mode-btn,html.standalone .panel,html.standalone .controls{display:revert!important}</style>\n<meta charset=\"utf-8\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no,viewport-fit=cover\"/>\n<link rel=\"icon\" href=\"data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAzMiAzMiI+PHJlY3QgZmlsbD0iIzBhMGEwYSIgd2lkdGg9IjMyIiBoZWlnaHQ9IjMyIi8+PGNpcmNsZSBjeD0iMTYiIGN5PSIxNiIgcj0iMTAiIGZpbGw9Im5vbmUiIHN0cm9rZT0iIzYwODBmZiIgc3Ryb2tlLXdpZHRoPSIxLjUiLz48L3N2Zz4=\"/>\n<title>Sprott Attractors</title>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nhtml,body{height:100%;height:100dvh;background:#080810;overflow:hidden}\ncanvas{display:block;width:100%;height:100%;touch-action:none}\n.back-btn{position:fixed;top:calc(12px + env(safe-area-inset-top));right:calc(12px + env(safe-area-inset-right));background:rgba(20,20,30,0.85);border:1px solid #334;color:#c0c8e0;padding:8px 14px;border-radius:6px;font:12px ui-monospace,monospace;cursor:pointer;text-decoration:none;backdrop-filter:blur(8px);z-index:1000;transition:border-color 0.2s}\n.back-btn:hover{border-color:#6080ff}\n.panel{position:fixed;top:calc(12px + env(safe-area-inset-top));left:calc(12px + env(safe-area-inset-left));background:rgba(8,8,16,0.82);border:1px solid #223;color:#a0b0d0;padding:12px 14px;border-radius:8px;font:12px/1.6 ui-monospace,monospace;backdrop-filter:blur(10px);z-index:100;max-width:min(320px,calc(100vw - 24px));pointer-events:none}\n.panel .name{font-size:14px;font-weight:600;color:#c0d0ff;margin-bottom:4px}\n.panel .eq{font-size:10px;line-height:1.8;color:#7090b0;white-space:pre}\n.controls{position:fixed;bottom:calc(12px + env(safe-area-inset-bottom));left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:100}\n.controls button{background:rgba(12,12,24,0.88);border:1px solid #334;color:#a0b8d8;padding:9px 18px;border-radius:6px;font:12px ui-monospace,monospace;cursor:pointer;backdrop-filter:blur(8px);transition:border-color 0.2s,color 0.2s;min-width:44px;min-height:44px}\n.controls button:hover{border-color:#6080ff;color:#c0d0ff}\n.controls button.active{border-color:#6080ff;color:#8090ff}\n</style>\n</head>\n<body>\n<a href=\"./\" class=\"back-btn\">← Gallery</a>\n<canvas id=\"c\"></canvas>\n<div class=\"panel\" id=\"panel\">\n  <div class=\"name\" id=\"sysname\">Thomas</div>\n  <div class=\"eq\" id=\"syseq\"></div>\n</div>\n<div class=\"controls\">\n  <button id=\"btnPrev\">prev</button>\n  <button id=\"btnNext\">next</button>\n  <button id=\"btnReset\">reset</button>\n  <button id=\"btnRotate\" class=\"active\">rotate</button>\n</div>\n<script>\nvar _raw=document.body.getAttribute('data-config');var cfg={};try{if(_raw)cfg=JSON.parse(_raw)}catch(e){}\nconst SYSTEMS = [\n  {\n    name: 'Thomas',\n    eq: 'ẋ = sin(y) − 0.208186·x\\nẏ = sin(z) − 0.208186·y\\nż = sin(x) − 0.208186·z',\n    init: [0.1, 0, 0],\n    scale: 0.22,\n    fn: (x,y,z) => [Math.sin(y)-0.208186*x, Math.sin(z)-0.208186*y, Math.sin(x)-0.208186*z]\n  },\n  {\n    name: 'Dadras',\n    eq: 'ẋ = y − 3x + 2.7yz\\nẏ = 1.7y − xz + z\\nż = 2xy − 9z',\n    init: [1, 2, 3],\n    scale: 0.18,\n    fn: (x,y,z) => [y-3*x+2.7*y*z, 1.7*y-x*z+z, 2*x*y-9*z]\n  },\n  {\n    name: 'Halvorsen',\n    eq: 'ẋ = −1.4x − 4y − 4z − y²\\nẏ = −1.4y − 4z − 4x − z²\\nż = −1.4z − 4x − 4y − x²',\n    init: [-5, 0, 1],\n    scale: 0.13,\n    fn: (x,y,z) => [-1.4*x-4*y-4*z-y*y, -1.4*y-4*z-4*x-z*z, -1.4*z-4*x-4*y-x*x]\n  },\n  {\n    name: 'Sprott B',\n    eq: 'ẋ = yz\\nẏ = x − y\\nż = 1 − xy',\n    init: [0.1, 0.1, 0.1],\n    scale: 0.42,\n    fn: (x,y,z) => [y*z, x-y, 1-x*y]\n  },\n  {\n    name: 'Sprott C',\n    eq: 'ẋ = yz\\nẏ = x − y\\nż = 1 − x²',\n    init: [0.1, 0.1, 0.1],\n    scale: 0.45,\n    fn: (x,y,z) => [y*z, x-y, 1-x*x]\n  },\n  {\n    name: 'Aizawa',\n    eq: 'ẋ = (z−0.7)x − 3.5y\\nẏ = 3.5x + (z−0.7)y\\nż = 0.6 + 0.95z − z³/3\\n    − (x²+y²)(1+0.25z) + 0.1z·x³',\n    init: [0.1, 1, 0.01],\n    scale: 0.85,\n    fn: (x,y,z) => [(z-0.7)*x-3.5*y, 3.5*x+(z-0.7)*y, 0.6+0.95*z-z*z*z/3-(x*x+y*y)*(1+0.25*z)+0.1*z*x*x*x]\n  },\n  {\n    name: 'Sprott D',\n    eq: 'ẋ = −y\\nẏ = x + z\\nż = xz + 3y²',\n    init: [0, 0, 1],\n    scale: 0.38,\n    fn: (x,y,z) => [-y, x+z, x*z+3*y*y]\n  },\n  {\n    name: 'Four-Wing',\n    eq: 'ẋ = 0.2x + yz\\nẏ = 0.01y − xz\\nż = −xy − z',\n    init: [1, 1, 1],\n    scale: 0.5,\n    fn: (x,y,z) => [0.2*x+y*z, 0.01*y-x*z, -x*y-z]\n  },\n  {\n    name: 'Linz-Sprott',\n    eq: 'ẋ = y\\nẏ = −x + yz\\nż = 1 − y²',\n    init: [0.1, 0, 0],\n    scale: 0.55,\n    fn: (x,y,z) => [y, -x+y*z, 1-y*y]\n  }\n];\n\nconst c = document.getElementById('c'), ctx = c.getContext('2d');\nlet W, H, dpr;\nconst MAX_TRAIL = cfg.trailLength??60000;\nlet trail = [];\nlet px = 0, py = 0, pz = 0;\nlet sysIdx = cfg.system?SYSTEMS.findIndex(s=>s.name===cfg.system):0;if(sysIdx<0)sysIdx=0;\nlet rotX = 0.4, rotY = 0.3;\nlet autoRotate = cfg.autoRotate??true;\nlet autoAngle = 0;\nlet animId;\n\nfunction resize() {\n  dpr = Math.min(devicePixelRatio || 1, 2);\n  W = innerWidth; H = innerHeight;\n  c.width = W * dpr; c.height = H * dpr;\n  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n}\n\nfunction resetSystem() {\n  const sys = SYSTEMS[sysIdx];\n  px = sys.init[0] + (Math.random()-0.5)*0.001;\n  py = sys.init[1] + (Math.random()-0.5)*0.001;\n  pz = sys.init[2] + (Math.random()-0.5)*0.001;\n  trail = [];\n  // warm-up\n  const dt = 0.004;\n  for (let i = 0; i < 2000; i++) {\n    [px,py,pz] = rk4(sys.fn, px, py, pz, dt);\n    if (!isFinite(px)||!isFinite(py)||!isFinite(pz)) {\n      px=sys.init[0]; py=sys.init[1]; pz=sys.init[2];\n    }\n  }\n  updatePanel();\n}\n\nfunction updatePanel() {\n  const sys = SYSTEMS[sysIdx];\n  document.getElementById('sysname').textContent = sys.name;\n  document.getElementById('syseq').textContent = sys.eq;\n}\n\nfunction rk4(fn, x, y, z, dt) {\n  const [k1x,k1y,k1z] = fn(x,y,z);\n  const [k2x,k2y,k2z] = fn(x+dt/2*k1x, y+dt/2*k1y, z+dt/2*k1z);\n  const [k3x,k3y,k3z] = fn(x+dt/2*k2x, y+dt/2*k2y, z+dt/2*k2z);\n  const [k4x,k4y,k4z] = fn(x+dt*k3x, y+dt*k3y, z+dt*k3z);\n  return [\n    x + dt/6*(k1x+2*k2x+2*k3x+k4x),\n    y + dt/6*(k1y+2*k2y+2*k3y+k4y),\n    z + dt/6*(k1z+2*k2z+2*k3z+k4z)\n  ];\n}\n\nfunction project(x, y, z) {\n  // Rotation around Y axis then X axis\n  const ry = autoRotate ? autoAngle : rotY;\n  const cosY = Math.cos(ry), sinY = Math.sin(ry);\n  const rx = rotX;\n  const cosX = Math.cos(rx), sinX = Math.sin(rx);\n\n  const x1 = x*cosY - z*sinY;\n  const z1 = x*sinY + z*cosY;\n  const y1 = y*cosX - z1*sinX;\n\n  const scale = SYSTEMS[sysIdx].scale * Math.min(W, H) * 0.45;\n  return [W/2 + x1*scale, H/2 + y1*scale];\n}\n\nlet frameCount = 0;\nfunction frame() {\n  animId = requestAnimationFrame(frame);\n  const sys = SYSTEMS[sysIdx];\n  const dt = 0.004;\n  const stepsPerFrame = 4;\n\n  // Fade background\n  ctx.fillStyle = 'rgba(8,8,16,0.05)';\n  ctx.fillRect(0, 0, W, H);\n\n  if (autoRotate) autoAngle += 0.003;\n\n  // Integrate\n  for (let s = 0; s < stepsPerFrame; s++) {\n    [px,py,pz] = rk4(sys.fn, px, py, pz, dt);\n    if (!isFinite(px)||!isFinite(py)||!isFinite(pz)) { resetSystem(); return; }\n    trail.push([px, py, pz]);\n    if (trail.length > MAX_TRAIL) trail.shift();\n  }\n\n  // Draw trail\n  const len = trail.length;\n  if (len < 2) return;\n\n  // Draw in segments for color gradient\n  const segSize = 200;\n  for (let i = 1; i < len; i++) {\n    const t = i / len;\n    // Hue: head=cyan/blue, tail=purple/red  (age coloring)\n    const hue = 200 + t * 200; // 200 (blue) to 400 (red, wraps to purple)\n    const alpha = 0.15 + t * 0.55;\n    const [x0, y0] = project(...trail[i-1]);\n    const [x1, y1] = project(...trail[i]);\n    // Skip if too far (attractor jump) \n    if (Math.hypot(x1-x0, y1-y0) > Math.min(W,H)*0.15) continue;\n    ctx.beginPath();\n    ctx.strokeStyle = `hsla(${hue%360},80%,65%,${alpha})`;\n    ctx.lineWidth = 1;\n    ctx.moveTo(x0, y0);\n    ctx.lineTo(x1, y1);\n    ctx.stroke();\n  }\n\n  // Draw current point\n  const [hx, hy] = project(px, py, pz);\n  ctx.beginPath();\n  ctx.arc(hx, hy, 2.5, 0, Math.PI*2);\n  ctx.fillStyle = '#fff';\n  ctx.fill();\n\n  frameCount++;\n}\n\n// Controls\ndocument.getElementById('btnNext').addEventListener('click', () => {\n  sysIdx = (sysIdx + 1) % SYSTEMS.length;\n  resetSystem();\n});\ndocument.getElementById('btnPrev').addEventListener('click', () => {\n  sysIdx = (sysIdx - 1 + SYSTEMS.length) % SYSTEMS.length;\n  resetSystem();\n});\ndocument.getElementById('btnReset').addEventListener('click', resetSystem);\ndocument.getElementById('btnRotate').addEventListener('click', function() {\n  autoRotate = !autoRotate;\n  this.classList.toggle('active', autoRotate);\n  if (autoRotate) rotY = autoAngle;\n});\n\n// Pointer drag\nlet dragging = false, lastPX = 0, lastPY = 0;\nc.addEventListener('pointerdown', e => {\n  dragging = true;\n  lastPX = e.clientX; lastPY = e.clientY;\n  c.setPointerCapture(e.pointerId);\n  if (autoRotate) { autoRotate = false; rotY = autoAngle; document.getElementById('btnRotate').classList.remove('active'); }\n});\nc.addEventListener('pointermove', e => {\n  if (!dragging) return;\n  const dx = e.clientX - lastPX, dy = e.clientY - lastPY;\n  rotY += dx * 0.005;\n  rotX += dy * 0.005;\n  rotX = Math.max(-Math.PI/2, Math.min(Math.PI/2, rotX));\n  lastPX = e.clientX; lastPY = e.clientY;\n});\nc.addEventListener('pointerup', () => { dragging = false; });\nc.addEventListener('pointercancel', () => { dragging = false; });\n\nwindow.addEventListener('resize', () => { resize(); resetSystem(); });\nif(window.visualViewport) window.visualViewport.addEventListener('resize', () => { resize(); resetSystem(); });\nwindow.addEventListener('orientationchange', () => { setTimeout(() => { resize(); resetSystem(); }, 200); });\n\nfunction start() {\n  resize();\n  if (c.width === 0 || c.height === 0) { requestAnimationFrame(start); return; }\n  resetSystem();\n  // In iframe: pre-fill trail so it's immediately visible, not just a dot\n  if (window.self !== window.top) {\n    const sys = SYSTEMS[sysIdx];\n    const dt = 0.004;\n    for (let i = 0; i < 20000; i++) {\n      [px,py,pz] = rk4(sys.fn, px, py, pz, dt);\n      if (!isFinite(px)||!isFinite(py)||!isFinite(pz)) { px=sys.init[0]; py=sys.init[1]; pz=sys.init[2]; }\n      trail.push([px, py, pz]);\n      if (trail.length > MAX_TRAIL) trail.shift();\n    }\n  }\n  frame();\n}\nrequestAnimationFrame(start);\n</script>\n</body>\n</html>\n",
  "config": {
    "width": "100%",
    "height": "100%",
    "system": { "type": "select", "label": "System", "default": "Thomas", "options": ["Thomas", "Dadras", "Halvorsen", "Sprott B", "Sprott C", "Aizawa", "Sprott D", "Four-Wing", "Linz-Sprott"] },
    "trailLength": { "type": "number", "label": "Trail Length", "default": 60000, "min": 10000, "max": 100000, "step": 5000 },
    "autoRotate": { "type": "boolean", "label": "Auto Rotate", "default": true }
  }
}

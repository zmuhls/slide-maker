{
  "id": "artifact-langton",
  "name": "Langton's Ant",
  "description": "Cellular automaton — a single ant turns and flips cells, chaos collapses into a repeating highway",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<style>.back-btn,#back,#info,#ui,#mode-btn{display:none!important}</style>\n<script>if(window.self===window.top)document.documentElement.classList.add('standalone')</script>\n<style>html.standalone .back-btn,html.standalone #back,html.standalone #info,html.standalone #ui,html.standalone #mode-btn{display:revert!important}</style>\n<meta charset=\"utf-8\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no,viewport-fit=cover\"/>\n<link rel=\"icon\" href=\"data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAzMiAzMiI+CiAgPHJlY3QgZmlsbD0iIzBhMGEwYSIgd2lkdGg9IjMyIiBoZWlnaHQ9IjMyIi8+CiAgPHBhdGggZD0iTTE2IDQgTDI4IDI4IEw0IDI4IFoiIGZpbGw9Im5vbmUiIHN0cm9rZT0iI2UwZTBlMCIgc3Ryb2tlLXdpZHRoPSIxLjUiLz4KPC9zdmc+Cg==\"/>\n<title>Langton's Ant</title>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nhtml,body{height:100%;height:100dvh;background:#0a0a0f;overflow:hidden}\ncanvas{display:block;width:100%;height:100%;image-rendering:pixelated;cursor:crosshair;touch-action:none}\n.back-btn{position:fixed;top:max(16px, env(safe-area-inset-top));right:max(16px, env(safe-area-inset-right));background:rgba(20,20,20,0.8);border:1px solid #444;color:#e0e0e0;padding:8px 14px;border-radius:6px;font:12px ui-monospace,monospace;cursor:pointer;text-decoration:none;backdrop-filter:blur(8px);z-index:1000;transition:border-color 0.2s}\n.back-btn:hover{border-color:#888}\n#steps{position:fixed;top:16px;left:16px;color:rgba(255,255,255,0.75);background:rgba(0,0,0,0.5);padding:4px 10px;border-radius:5px;font:13px ui-monospace,monospace;pointer-events:none}\n#info{position:fixed;bottom:16px;left:16px;color:rgba(255,255,255,0.9);background:rgba(0,0,0,0.6);padding:6px 12px;border-radius:6px;font:13px/1.6 ui-monospace,monospace;pointer-events:none}\n</style>\n</head>\n<body>\n<canvas id=\"c\"></canvas>\n<a href=\"./\" class=\"back-btn\" id=\"backbtn\">← Gallery</a>\n<div id=\"steps\">step 0</div>\n<div id=\"info\">Langton's Ant · space pause · r reset · +/− speed · click add ant</div>\n<script>\nif(window.self!==window.top){\n  document.getElementById('backbtn').style.display='none';\n  document.getElementById('info').style.display='none';\n  document.getElementById('steps').style.display='none';\n}\n\nvar _raw=document.body.getAttribute('data-config');var cfg={};try{if(_raw)cfg=JSON.parse(_raw)}catch(e){}\nconst c=document.getElementById('c'),ctx=c.getContext('2d');\nconst CELL=cfg.cellSize??3;\n// Directions: 0=N 1=E 2=S 3=W\nconst DX=[0,1,0,-1],DY=[-1,0,1,0];\n\nlet cols,rows,grid,ants=[],step=0,running=true,spf=cfg.stepsPerFrame??50;\n\nconst PALETTE=[\n  [10,10,20],    // state 0: dark bg\n  [230,180,60],  // state 1: amber\n];\n\nfunction rng(n){return Math.floor(Math.random()*n)}\n\nfunction makeAnt(x,y,hue){\n  return {x,y,d:rng(4),h:hue};\n}\n\nfunction init(){\n  const pw=Math.floor(innerWidth/CELL);\n  const ph=Math.floor(innerHeight/CELL);\n  c.width=pw; c.height=ph;\n  cols=pw; rows=ph;\n  grid=new Uint8Array(cols*rows);\n  ants=[];for(var _i=0;_i<(cfg.startingAnts??1);_i++)ants.push(makeAnt(Math.floor(cols/2)+_i*3,Math.floor(rows/2),120+_i*60));\n  step=0;\n}\n\nfunction tick(){\n  for(const a of ants){\n    const i=a.y*cols+a.x;\n    const s=grid[i];\n    // RL rule: state 0 turn right (+1), state 1 turn left (-1)\n    a.d=((a.d+(s===0?1:-1))+4)%4;\n    grid[i]=1-s;\n    a.x=(a.x+DX[a.d]+cols)%cols;\n    a.y=(a.y+DY[a.d]+rows)%rows;\n  }\n  step++;\n}\n\nfunction draw(){\n  const img=ctx.getImageData(0,0,cols,rows);\n  const d=img.data;\n  for(let i=0;i<cols*rows;i++){\n    const s=grid[i];\n    const b=i*4;\n    const p=PALETTE[s];\n    d[b]=p[0];d[b+1]=p[1];d[b+2]=p[2];d[b+3]=255;\n  }\n  // Mark ant positions\n  for(const a of ants){\n    const b=(a.y*cols+a.x)*4;\n    // hue to rgb fast approx\n    const h=a.h/360,hi=Math.floor(h*6),f=h*6-hi;\n    const q=Math.floor((1-f)*255),t=Math.floor(f*255);\n    const [r,g,bl]=[[255,t,0],[q,255,0],[0,255,t],[0,q,255],[t,0,255],[255,0,q]][hi%6];\n    d[b]=r;d[b+1]=g;d[b+2]=bl;d[b+3]=255;\n  }\n  ctx.putImageData(img,0,0);\n  document.getElementById('steps').textContent=`step ${step.toLocaleString()}  ants ${ants.length}`;\n}\n\nfunction loop(){\n  if(running)for(let i=0;i<spf;i++)tick();\n  draw();\n  requestAnimationFrame(loop);\n}\n\naddEventListener('resize',init);\nif(window.visualViewport)window.visualViewport.addEventListener('resize',init);\naddEventListener('orientationchange',()=>{setTimeout(init,200);});\nrequestAnimationFrame(()=>{init();setTimeout(init,200);loop();});\naddEventListener('keydown',e=>{\n  if(e.code==='Space'){e.preventDefault();running=!running}\n  if(e.code==='KeyR')init();\n  if(e.key==='+'||e.key==='=')spf=Math.min(spf*2,5000);\n  if(e.key==='-')spf=Math.max(1,Math.floor(spf/2));\n});\nc.addEventListener('click',e=>{\n  const r=c.getBoundingClientRect();\n  const x=Math.floor((e.clientX-r.left)/r.width*cols);\n  const y=Math.floor((e.clientY-r.top)/r.height*rows);\n  ants.push(makeAnt(x,y,Math.random()*360));\n});\nc.addEventListener('touchend',e=>{\n  e.preventDefault();\n  const t=e.changedTouches[0];\n  const r=c.getBoundingClientRect();\n  const x=Math.floor((t.clientX-r.left)/r.width*cols);\n  const y=Math.floor((t.clientY-r.top)/r.height*rows);\n  ants.push(makeAnt(x,y,Math.random()*360));\n},{passive:false});\n</script>\n</body>\n</html>\n",
  "config": {
    "cellSize": { "type": "number", "label": "Cell Size", "default": 3, "min": 1, "max": 8, "step": 1 },
    "stepsPerFrame": { "type": "number", "label": "Steps Per Frame", "default": 50, "min": 1, "max": 500, "step": 1 },
    "startingAnts": { "type": "number", "label": "Starting Ants", "default": 1, "min": 1, "max": 5, "step": 1 }
  }
}

{
  "id": "artifact-leaflet",
  "name": "Leaflet Tile Map (OSM)",
  "description": "Pannable/zoomable slippy map using OpenStreetMap tiles (no external JS libs). Configure lat/lng/zoom and tile URL.",
  "type": "map",
  "source": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no\"><style>html,body{height:100%;margin:0}body{background:#0b1220;color:#e2e8f0;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Inter,sans-serif;overflow:hidden}#map{position:relative;width:100%;height:100%}#hud{position:absolute;left:10px;top:10px;background:rgba(15,23,42,.65);backdrop-filter:blur(4px);padding:6px 8px;border:1px solid rgba(148,163,184,.2);border-radius:6px;font-size:12px;z-index:2}#hud b{color:#93c5fd}.tile{position:absolute;image-rendering:pixelated;}</style></head><body><div id=\"map\"></div><div id=\"hud\"></div><script>const el=document.currentScript?.parentElement||document.body;let cfg={};try{const raw=el.getAttribute('data-config');if(raw)cfg=JSON.parse(raw)}catch(e){}const TILE_URL=(cfg.tileUrl||'https://a.tile.openstreetmap.org/{z}/{x}/{y}.png');let lat=typeof cfg.lat==='number'?cfg.lat:40.7128;let lng=typeof cfg.lng==='number'?cfg.lng:-74.0060;let zoom=Math.max( (cfg.minZoom??2), Math.min((cfg.zoom??4),(cfg.maxZoom??18)) );const minZoom=cfg.minZoom??2,maxZoom=cfg.maxZoom??18;const map=document.getElementById('map');const hud=document.getElementById('hud');const TILE=256;function lon2x(lon,z){return (lon+180)/360*Math.pow(2,z)}function lat2y(lat,z){const rad=lat*Math.PI/180;return (1-Math.log(Math.tan(rad)+1/Math.cos(rad))/Math.PI)/2*Math.pow(2,z)}function x2lon(x,z){return x/Math.pow(2,z)*360-180}function y2lat(y,z){const n=Math.PI-2*Math.PI*y/Math.pow(2,z);return 180/Math.PI*Math.atan(0.5*(Math.exp(n)-Math.exp(-n)))}let cx=lon2x(lng,zoom),cy=lat2y(lat,zoom);let raf=null;let tiles=[];function clearTiles(){for(const t of tiles){t.remove()}tiles.length=0}function render(){cancelAnimationFrame(raf);raf=requestAnimationFrame(()=>{const w=map.clientWidth,h=map.clientHeight;const startX=Math.floor(cx-w/(2*TILE));const endX=Math.floor(cx+w/(2*TILE));const startY=Math.floor(cy-h/(2*TILE));const endY=Math.floor(cy+h/(2*TILE));clearTiles();for(let x=startX-1;x<=endX+1;x++){for(let y=startY-1;y<=endY+1;y++){const img=document.createElement('img');img.className='tile';const dx=(x-cx)*TILE+w/2;const dy=(y-cy)*TILE+h/2;img.style.left=dx+'px';img.style.top=dy+'px';img.width=TILE;img.height=TILE;const X=((x%Math.pow(2,zoom))+Math.pow(2,zoom))%Math.pow(2,zoom);const Y=y; if(Y<0||Y>=Math.pow(2,zoom)) continue;const url=TILE_URL.replace('{z}',zoom).replace('{x}',X).replace('{y}',Y).replace('{s}','a');img.referrerPolicy='origin-when-cross-origin';img.decoding='async';img.loading='lazy';img.src=url;tiles.push(img);map.appendChild(img);}}hud.innerHTML='<b>Lat</b> '+lat.toFixed(4)+' <b>Lng</b> '+lng.toFixed(4)+' <b>Z</b> '+zoom;});}let dragging=false;let lastX=0,lastY=0;map.addEventListener('mousedown',(e)=>{dragging=true;lastX=e.clientX;lastY=e.clientY});window.addEventListener('mouseup',()=>dragging=false);window.addEventListener('mousemove',(e)=>{if(!dragging) return;const dx=e.clientX-lastX;const dy=e.clientY-lastY;lastX=e.clientX;lastY=e.clientY;cx-=dx/TILE;cy-=dy/TILE;lng=x2lon(cx,zoom);lat=y2lat(cy,zoom);render()},{passive:true});map.addEventListener('wheel',(e)=>{e.preventDefault();const dir=e.deltaY>0?-1:1;const nz=Math.max(minZoom,Math.min(maxZoom,zoom+dir));if(nz===zoom) return;const f=Math.pow(2,nz-zoom);cx*=f;cy*=f;zoom=nz;lng=x2lon(cx,zoom);lat=y2lat(cy,zoom);render()},{passive:false});window.addEventListener('resize',render);render();</script></body></html>",
  "config": {
    "lat": { "type": "number", "label": "Latitude", "default": 40.7128, "min": -85, "max": 85, "step": 0.0001 },
    "lng": { "type": "number", "label": "Longitude", "default": -74.006, "min": -180, "max": 180, "step": 0.0001 },
    "zoom": { "type": "number", "label": "Zoom", "default": 4, "min": 2, "max": 18, "step": 1 },
    "tileUrl": { "type": "string", "label": "Tile URL", "default": "https://a.tile.openstreetmap.org/{z}/{x}/{y}.png" }
  }
}

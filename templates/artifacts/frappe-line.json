{
  "id": "artifact-frappe-line",
  "name": "Line Chart",
  "description": "Smooth line chart with area fill, tooltips, and animation. Configure labels, datasets, colors, and y-axis minimum.",
  "type": "chart",
  "source": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><style>*{margin:0;padding:0;box-sizing:border-box}body{background:transparent;overflow:hidden;font-family:Inter,system-ui,sans-serif}#chart{width:100%;min-height:200px}.frappe-chart .axis text,.frappe-chart .chart-label{fill:#94a3b8!important}.frappe-chart .axis line{stroke:#334155!important}</style></head><body data-config=\"{}\"><div id=\"chart\"></div><script src=\"/api/static/frappe-charts.min.umd.js\"><\/script><script>function initChart(){try{var cfg=JSON.parse(document.body.getAttribute('data-config')||'{}');var el=document.getElementById('chart');var d=cfg.data||{labels:['Jan','Feb','Mar','Apr','May','Jun'],datasets:[{name:'Trend',values:[120,180,150,210,170,230]}]};var c=cfg.colors||['#0ea5e9'];var h=Math.max(200,document.documentElement.clientHeight-20);var opts={data:d,type:'line',height:h,colors:c,animate:1,truncateLegends:1,lineOptions:{regionFill:1,hideDots:0,spline:1}};if(cfg.yMin!=null)opts.yMinValue=cfg.yMin;var chart=new frappe.Chart(el,opts);var tid=0;new ResizeObserver(function(){clearTimeout(tid);tid=setTimeout(function(){var nh=Math.max(200,document.documentElement.clientHeight-20);var ro={data:d,type:'line',height:nh,colors:c,animate:0,truncateLegends:1,lineOptions:{regionFill:1,hideDots:0,spline:1}};if(cfg.yMin!=null)ro.yMinValue=cfg.yMin;chart=new frappe.Chart(el,ro)},150)}).observe(document.body)}catch(e){var p=document.createElement('p');p.style.cssText='color:#f87171;padding:20px';p.textContent='Chart error: '+e.message;document.body.appendChild(p)}}function waitForLayout(){var el=document.getElementById('chart');if(el&&el.offsetWidth>0){initChart()}else{requestAnimationFrame(waitForLayout)}}requestAnimationFrame(waitForLayout)<\/script></body></html>",
  "config": {
    "data": {
      "type": "object",
      "label": "Chart Data",
      "default": {
        "labels": ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
        "datasets": [{ "name": "Trend", "values": [120, 180, 150, 210, 170, 230] }]
      }
    },
    "colors": {
      "type": "array",
      "label": "Line Colors",
      "default": ["#0ea5e9"]
    },
    "yMin": {
      "type": "number",
      "label": "Y-Axis Minimum",
      "default": null
    }
  }
}

{
  "id": "artifact-rossler",
  "name": "Rössler Attractor",
  "description": "Three-variable chaotic attractor with a single nonlinearity",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<style>.back,.back-btn,#back,#info,#ui,#mode-btn,.panel,.controls,.hint{display:none!important}</style>\n<script>if(window.self===window.top)document.documentElement.classList.add('standalone')</script>\n<style>html.standalone .back,html.standalone .back-btn,html.standalone #back,html.standalone #info,html.standalone #ui,html.standalone #mode-btn,html.standalone .panel,html.standalone .controls,html.standalone .hint{display:revert!important}</style>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover\">\n<title>Rössler Attractor</title>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nhtml,body{height:100%;height:100dvh;background:#050508;overflow:hidden;display:flex;flex-direction:column}\ncanvas{display:block;flex:1;width:100%;touch-action:none}\n.back{position:fixed;top:max(1rem, env(safe-area-inset-top));left:max(1rem, env(safe-area-inset-left));font:0.8rem/1 ui-monospace,SFMono-Regular,Menlo,monospace;color:#aaa;background:rgba(5,5,8,0.88);padding:0.5rem 0.8rem;border-radius:4px;text-decoration:none;border:1px solid #333;z-index:10;transition:border-color 0.2s}\n.back:hover{border-color:#666;color:#fff}\n.panel{background:#0a0a10;border-top:1px solid #1a1a28;padding:0.65rem 0.9rem;display:flex;justify-content:space-between;align-items:center;gap:0.75rem;font:0.75rem/1 ui-monospace,SFMono-Regular,Menlo,monospace;flex-wrap:wrap;flex-shrink:0}\n.panel .meta{display:flex;align-items:center;gap:0.6rem;color:#d47070}\n.panel .hint{color:#653535}\n.panel .params{display:flex;align-items:center;gap:0.4rem;color:#aa5555;font-size:0.7rem}\n.panel .controls{display:flex;align-items:center;gap:0.55rem;flex-wrap:wrap}\n.panel button{background:rgba(255,255,255,0.05);border:1px solid #4a2020;color:#c47070;font:0.75rem ui-monospace,SFMono-Regular,Menlo,monospace;padding:8px 14px;border-radius:4px;cursor:pointer;transition:all 0.2s;-webkit-tap-highlight-color:transparent}\n.panel button:hover{background:rgba(255,255,255,0.1);color:#f0a0a0;border-color:#8a4040}\n@media(max-width:760px){.panel{padding:0.5rem}.panel .params{font-size:0.65rem}}\n</style>\n</head>\n<body>\n<a class=\"back\" href=\"./\">← gallery</a>\n<canvas id=\"c\"></canvas>\n<div class=\"panel\">\n  <div class=\"meta\">\n    <span>Rössler Attractor</span>\n    <span class=\"hint\">dx/dt = −y − z &nbsp;|&nbsp; dy/dt = x + ay &nbsp;|&nbsp; dz/dt = b + z(x − c)</span>\n  </div>\n  <div class=\"controls\">\n    <span class=\"params\" id=\"paramDisplay\">a=0.20 b=0.20 c=5.70</span>\n    <button id=\"resetBtn\">reset</button>\n    <button id=\"presetBtn\">preset</button>\n    <button id=\"viewBtn\">rotate</button>\n  </div>\n</div>\n<script>\nvar _raw=document.body.getAttribute('data-config');var cfg={};try{if(_raw)cfg=JSON.parse(_raw)}catch(e){}\nconst canvas=document.getElementById('c');\nconst ctx=canvas.getContext('2d');\nlet W=0,H=0;\n\nconst PRESETS=[\n  {a:0.2, b:0.2, c:5.7, label:'classic'},\n  {a:0.1, b:0.1, c:14, label:'funnel'},\n  {a:0.2, b:0.2, c:9, label:'screw'},\n  {a:0.35,b:0.3, c:9.3, label:'spiral'},\n  {a:0.2, b:0.2, c:3.5, label:'period-1'},\n  {a:0.25,b:0.2, c:7.5, label:'band'},\n];\nlet presetIdx=0;\n\nlet pa=cfg.a??0.2, pb=cfg.b??0.2, pc=cfg.c??5.7;\nlet dt=cfg.speed??0.005;\n\n// Trail storage\nconst MAX_POINTS=cfg.trailLength??60000;\nlet points=[];\nlet x=0.1, y=0, z=0;\n\n// View rotation\nlet rotY=0;\nlet rotX=-0.3;\nlet autoRotate=true;\nlet dragging=false;\nlet lastMX=0, lastMY=0;\n\nfunction resize(){\n  const dpr=Math.min(window.devicePixelRatio||1,2);\n  const nw=canvas.offsetWidth, nh=canvas.offsetHeight;\n  if(nw<1||nh<1) return;\n  if(nw===W&&nh===H) return;\n  W=nw; H=nh;\n  canvas.width=W*dpr; canvas.height=H*dpr;\n  ctx.setTransform(dpr,0,0,dpr,0,0);\n}\n\nfunction step(){\n  const dx=-y-z;\n  const dy=x+pa*y;\n  const dz=pb+z*(x-pc);\n  x+=dx*dt; y+=dy*dt; z+=dz*dt;\n  // Divergence check\n  if(Math.abs(x)>500||Math.abs(y)>500||Math.abs(z)>500){\n    x=0.1; y=0; z=0; points=[];\n  }\n  points.push({x:x,y:y,z:z});\n  if(points.length>MAX_POINTS) points.shift();\n}\n\nfunction project(px,py,pz){\n  // Rotate around Y axis\n  const cosY=Math.cos(rotY), sinY=Math.sin(rotY);\n  let rx=px*cosY-pz*sinY;\n  let rz=px*sinY+pz*cosY;\n  // Rotate around X axis\n  const cosX=Math.cos(rotX), sinX=Math.sin(rotX);\n  let ry=py*cosX-rz*sinX;\n  rz=py*sinX+rz*cosX;\n\n  const scale=Math.min(W,H)/28;\n  return {\n    x: W/2+rx*scale,\n    y: H/2+ry*scale,\n    z: rz\n  };\n}\n\nfunction draw(){\n  ctx.fillStyle='rgba(5,5,8,0.15)';\n  ctx.fillRect(0,0,W,H);\n\n  if(points.length<2) return;\n\n  const len=points.length;\n  for(let i=1;i<len;i++){\n    const p0=project(points[i-1].x,points[i-1].y,points[i-1].z);\n    const p1=project(points[i].x,points[i].y,points[i].z);\n\n    const age=i/len;\n    const alpha=0.15+age*age*0.75;\n    // Color: depth-mapped warm palette\n    const hue=200+(p1.z+20)*4;\n    ctx.strokeStyle=`hsla(${hue},70%,${45+age*20}%,${alpha})`;\n    ctx.lineWidth=0.5+age*1.5;\n    ctx.beginPath();\n    ctx.moveTo(p0.x,p0.y);\n    ctx.lineTo(p1.x,p1.y);\n    ctx.stroke();\n  }\n\n  // Draw current point\n  const cur=project(x,y,z);\n  ctx.fillStyle='#ff6060';\n  ctx.beginPath();\n  ctx.arc(cur.x,cur.y,3,0,Math.PI*2);\n  ctx.fill();\n}\n\nfunction loop(){\n  resize();\n  if(autoRotate) rotY+=0.003;\n  for(let i=0;i<8;i++) step();\n  draw();\n  requestAnimationFrame(loop);\n}\n\nfunction resetSim(){\n  x=0.1; y=0; z=0;\n  points=[];\n  ctx.fillStyle='#050508';\n  ctx.fillRect(0,0,W,H);\n}\n\nfunction updateDisplay(){\n  document.getElementById('paramDisplay').textContent=\n    'a='+pa.toFixed(2)+' b='+pb.toFixed(2)+' c='+pc.toFixed(2);\n}\n\ndocument.getElementById('resetBtn').addEventListener('click',function(){\n  resetSim();\n});\n\ndocument.getElementById('presetBtn').addEventListener('click',function(){\n  presetIdx=(presetIdx+1)%PRESETS.length;\n  const p=PRESETS[presetIdx];\n  pa=p.a; pb=p.b; pc=p.c;\n  updateDisplay();\n  resetSim();\n});\n\ndocument.getElementById('viewBtn').addEventListener('click',function(){\n  autoRotate=!autoRotate;\n  this.textContent=autoRotate?'rotate':'manual';\n});\n\n// Pointer drag for manual rotation\ncanvas.addEventListener('pointerdown',function(e){\n  if(e.button!==0) return;\n  dragging=true;\n  lastMX=e.clientX; lastMY=e.clientY;\n  canvas.setPointerCapture(e.pointerId);\n  autoRotate=false;\n  document.getElementById('viewBtn').textContent='manual';\n});\ncanvas.addEventListener('pointermove',function(e){\n  if(!dragging) return;\n  rotY+=(e.clientX-lastMX)*0.005;\n  rotX+=(e.clientY-lastMY)*0.005;\n  rotX=Math.max(-Math.PI/2,Math.min(Math.PI/2,rotX));\n  lastMX=e.clientX; lastMY=e.clientY;\n});\ncanvas.addEventListener('pointerup',function(){dragging=false;});\ncanvas.addEventListener('pointercancel',function(){dragging=false;});\n\n// In iframe: pre-run many steps so the trail is dense and visible immediately\nif(window.self!==window.top){\n  for(let i=0;i<30000;i++) step();\n}\n\nrequestAnimationFrame(function(){requestAnimationFrame(loop);});\n</script>\n</body>\n</html>\n",
  "config": {
    "width": "100%",
    "height": "100%",
    "a": { "type": "number", "label": "Parameter a", "default": 0.2, "min": 0.05, "max": 0.5, "step": 0.01 },
    "b": { "type": "number", "label": "Parameter b", "default": 0.2, "min": 0.05, "max": 0.5, "step": 0.01 },
    "c": { "type": "number", "label": "Parameter c", "default": 5.7, "min": 2, "max": 15, "step": 0.1 },
    "trailLength": { "type": "number", "label": "Trail Length", "default": 60000, "min": 10000, "max": 100000, "step": 5000 },
    "speed": { "type": "number", "label": "Speed (dt)", "default": 0.005, "min": 0.001, "max": 0.02, "step": 0.001 }
  }
}

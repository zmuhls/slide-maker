{
  "id": "artifact-boids",
  "name": "Boids",
  "description": "Flocking simulation with emergent swarming behavior",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<style>.back-btn,#back,#info,#ui,#mode-btn{display:none!important}</style>\n<script>if(window.self===window.top)document.documentElement.classList.add('standalone')</script>\n<style>html.standalone .back-btn,html.standalone #back,html.standalone #info,html.standalone #ui,html.standalone #mode-btn{display:revert!important}</style>\n<meta charset=\"utf-8\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no,viewport-fit=cover\"/>\n<link rel=\"icon\" href=\"data:image/svg+xml;base64,\"/>\n<title>Boids</title>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nhtml,body{height:100%;height:100dvh;background:#05070b;overflow:hidden}\ncanvas{display:block;width:100%;height:100%;touch-action:none}\n#info{position:fixed;bottom:calc(12px + env(safe-area-inset-bottom));left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.9);background:rgba(0,0,0,0.6);padding:6px 12px;border-radius:6px;text-shadow:0 1px 3px rgba(0,0,0,0.9);font:13px/1.4 ui-monospace,monospace;pointer-events:none;text-align:center}\n.back-btn{position:fixed;top:calc(12px + env(safe-area-inset-top));right:calc(12px + env(safe-area-inset-right));background:rgba(20,20,20,0.8);border:1px solid #444;color:#e0e0e0;padding:8px 14px;border-radius:6px;font:12px ui-monospace,monospace;cursor:pointer;text-decoration:none;backdrop-filter:blur(8px);z-index:1000;transition:border-color 0.2s}\n.back-btn:hover{border-color:#888}\n</style>\n</head>\n<body>\n<a href=\"./\" class=\"back-btn\">← Gallery</a>\n<canvas id=\"c\"></canvas>\n<div id=\"info\">Boids (Craig Reynolds, 1986) · move mouse to attract · click to reseed</div>\n<script>\nvar _raw=document.body.getAttribute('data-config');var cfg={};try{if(_raw)cfg=JSON.parse(_raw)}catch(e){}\nvar sepR=cfg.separationRadius??18,aliR=cfg.alignmentRadius??42,cohR=cfg.cohesionRadius??52,sepW=cfg.separationWeight??1.35,aliW=cfg.alignmentWeight??0.85,cohW=cfg.cohesionWeight??0.65;\nconst c=document.getElementById('c'),ctx=c.getContext('2d');\nlet W,H,px=null,py=null;\nconst N=cfg.count??120,boid=[];\n\nfunction resize(){W=c.width=innerWidth;H=c.height=innerHeight}\nfunction reset(){\n  boid.length=0;\n  for(let i=0;i<N;i++)boid.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()*2-1)*0.8,vy:(Math.random()*2-1)*0.8});\n}\naddEventListener('resize',()=>{resize();reset()});\nif(window.visualViewport)window.visualViewport.addEventListener('resize',()=>{resize();});\nwindow.addEventListener('orientationchange',()=>requestAnimationFrame(resize));\nrequestAnimationFrame(()=>{resize();setTimeout(()=>{resize();reset()},200);reset();loop();});\naddEventListener('click',reset);\naddEventListener('mousemove',e=>{px=e.clientX;py=e.clientY});\naddEventListener('mouseleave',()=>{px=py=null});\naddEventListener('touchmove',e=>{px=e.touches[0].clientX;py=e.touches[0].clientY},{passive:true});\naddEventListener('touchend',()=>{px=py=null});\n\nconst maxSpeed=cfg.maxSpeed??2.2,maxForce=0.06;\nfunction wrap(b){if(b.x<-20)b.x=W+20;if(b.x>W+20)b.x=-20;if(b.y<-20)b.y=H+20;if(b.y>H+20)b.y=-20}\n\nfunction loop(){\n  ctx.fillStyle='#05070b';ctx.fillRect(0,0,W,H);\n  for(let i=0;i<N;i++){\n    const b=boid[i];\n    let sx=0,sy=0,sa=0,ax=0,ay=0,aa=0,cx=0,cy=0,ca=0;\n    for(let j=0;j<N;j++){\n      if(i===j)continue;const o=boid[j];\n      const dx=o.x-b.x,dy=o.y-b.y,d2=dx*dx+dy*dy;\n      if(d2<0.0001)continue;\n      if(d2<sepR*sepR){const d=Math.sqrt(d2);sx-=dx/d;sy-=dy/d;sa++}\n      if(d2<aliR*aliR){ax+=o.vx;ay+=o.vy;aa++}\n      if(d2<cohR*cohR){cx+=o.x;cy+=o.y;ca++}\n    }\n    let fx=0,fy=0;\n    if(sa){sx/=sa;sy/=sa;const m=Math.hypot(sx,sy)||1;sx=(sx/m)*maxSpeed-b.vx;sy=(sy/m)*maxSpeed-b.vy;const sm=Math.hypot(sx,sy)||1;if(sm>maxForce){sx=(sx/sm)*maxForce;sy=(sy/sm)*maxForce}fx+=sx*sepW;fy+=sy*sepW}\n    if(aa){ax/=aa;ay/=aa;const m=Math.hypot(ax,ay)||1;ax=(ax/m)*maxSpeed-b.vx;ay=(ay/m)*maxSpeed-b.vy;const am=Math.hypot(ax,ay)||1;if(am>maxForce){ax=(ax/am)*maxForce;ay=(ay/am)*maxForce}fx+=ax*aliW;fy+=ay*aliW}\n    if(ca){cx=cx/ca-b.x;cy=cy/ca-b.y;const m=Math.hypot(cx,cy)||1;cx=(cx/m)*maxSpeed-b.vx;cy=(cy/m)*maxSpeed-b.vy;const cm=Math.hypot(cx,cy)||1;if(cm>maxForce){cx=(cx/cm)*maxForce;cy=(cy/cm)*maxForce}fx+=cx*cohW;fy+=cy*cohW}\n    if(px!=null){const dx=px-b.x,dy=py-b.y,d=Math.hypot(dx,dy)||1;const pull=Math.min(1,180/d)*0.015;fx+=(dx/d)*pull;fy+=(dy/d)*pull}\n    b.vx+=fx;b.vy+=fy;const sp=Math.hypot(b.vx,b.vy)||1;if(sp>maxSpeed){b.vx=(b.vx/sp)*maxSpeed;b.vy=(b.vy/sp)*maxSpeed}\n    b.x+=b.vx;b.y+=b.vy;wrap(b);\n  }\n  ctx.fillStyle='rgba(192,192,192,0.7)';ctx.strokeStyle='rgba(255,255,255,0.2)';ctx.lineWidth=1;\n  for(const b of boid){\n    const a=Math.atan2(b.vy,b.vx),s=7;\n    ctx.beginPath();ctx.moveTo(b.x+Math.cos(a)*s,b.y+Math.sin(a)*s);\n    ctx.lineTo(b.x+Math.cos(a+2.4)*s*0.75,b.y+Math.sin(a+2.4)*s*0.75);\n    ctx.lineTo(b.x+Math.cos(a-2.4)*s*0.75,b.y+Math.sin(a-2.4)*s*0.75);\n    ctx.closePath();ctx.fill();ctx.stroke();\n  }\n  requestAnimationFrame(loop);\n}\n</script>\n\n</body>\n</html>\n",
  "config": {
    "width": "100%",
    "height": "100%",
    "count": { "type": "number", "label": "Boid Count", "default": 120, "min": 20, "max": 400, "step": 10 },
    "maxSpeed": { "type": "number", "label": "Max Speed", "default": 2.2, "min": 0.5, "max": 5, "step": 0.1 },
    "separationRadius": { "type": "number", "label": "Separation Radius", "default": 18, "min": 5, "max": 50 },
    "alignmentRadius": { "type": "number", "label": "Alignment Radius", "default": 42, "min": 10, "max": 100 },
    "cohesionRadius": { "type": "number", "label": "Cohesion Radius", "default": 52, "min": 10, "max": 120 },
    "separationWeight": { "type": "number", "label": "Separation Weight", "default": 1.35, "min": 0, "max": 3, "step": 0.05 },
    "alignmentWeight": { "type": "number", "label": "Alignment Weight", "default": 0.85, "min": 0, "max": 3, "step": 0.05 },
    "cohesionWeight": { "type": "number", "label": "Cohesion Weight", "default": 0.65, "min": 0, "max": 3, "step": 0.05 }
  }
}

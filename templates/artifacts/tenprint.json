{
  "id": "artifact-tenprint",
  "name": "10 PRINT",
  "description": "Classic one-liner generative pattern from the Commodore 64 era",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<style>.back-btn,#back,#info,#ui,#mode-btn{display:none!important}</style>\n<script>if(window.self===window.top)document.documentElement.classList.add('standalone')</script>\n<style>html.standalone .back-btn,html.standalone #back,html.standalone #info,html.standalone #ui,html.standalone #mode-btn{display:revert!important}</style>\n<meta charset=\"utf-8\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no,viewport-fit=cover\"/>\n<link rel=\"icon\" href=\"data:image/svg+xml;base64,\"/>\n<title>10 PRINT</title>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nhtml,body{height:100%;height:100dvh;background:#050b07;overflow:hidden}\ncanvas{display:block;width:100%;height:100%;touch-action:none}\n#info{position:fixed;bottom:16px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.9);background:rgba(0,0,0,0.6);padding:6px 12px;border-radius:6px;text-shadow:0 1px 3px rgba(0,0,0,0.9);font:13px/1.4 ui-monospace,monospace;pointer-events:none;text-align:center}\n.back-btn{position:fixed;top:max(16px, env(safe-area-inset-top));right:max(16px, env(safe-area-inset-right));background:rgba(20,20,20,0.8);border:1px solid #444;color:#e0e0e0;padding:8px 14px;border-radius:6px;font:12px ui-monospace,monospace;cursor:pointer;text-decoration:none;backdrop-filter:blur(8px);z-index:1000;transition:border-color 0.2s}\n.back-btn:hover{border-color:#888}\n</style>\n</head>\n<body>\n<a href=\"./\" class=\"back-btn\">← Gallery</a>\n<canvas id=\"c\"></canvas>\n<div id=\"info\">10 PRINT CHR$(205.5+RND(1)); : GOTO 10 — Commodore 64, 1982 · click to regenerate</div>\n<script>\nvar _raw=document.body.getAttribute('data-config');var cfg={};try{if(_raw)cfg=JSON.parse(_raw)}catch(e){}\nconst c=document.getElementById('c'),ctx=c.getContext('2d');\nlet W,H,x=0,y=0;\nconst SIZE=cfg.cellSize??22;\n\nfunction resize(){W=c.width=innerWidth;H=c.height=innerHeight;x=0;y=0;ctx.fillStyle=cfg.bgColor??'#050b07';ctx.fillRect(0,0,W,H);ctx.strokeStyle=cfg.color??'#c0c0c0';ctx.lineWidth=cfg.lineWidth??2;ctx.lineCap='square'}\naddEventListener('resize',resize);\nif(window.visualViewport)window.visualViewport.addEventListener('resize',()=>{resize();});\nwindow.addEventListener('orientationchange',()=>requestAnimationFrame(resize));\nrequestAnimationFrame(()=>{resize()});\naddEventListener('click',resize);\n\nvar _inIframe=false;try{_inIframe=window.self!==window.top}catch(e){_inIframe=true}\nvar _linesPerFrame=_inIframe?1:6;\nfunction loop(){\n  for(let i=0;i<_linesPerFrame;i++){\n    if(y>=H){x=0;y=0;ctx.fillStyle=cfg.bgColor??'#050b07';ctx.fillRect(0,0,W,H);ctx.strokeStyle=cfg.color??'#c0c0c0';ctx.lineWidth=cfg.lineWidth??2;ctx.lineCap='square';return requestAnimationFrame(loop)}\n    ctx.beginPath();\n    if(Math.random()>0.5){ctx.moveTo(x,y);ctx.lineTo(x+SIZE,y+SIZE)}\n    else{ctx.moveTo(x+SIZE,y);ctx.lineTo(x,y+SIZE)}\n    ctx.stroke();\n    x+=SIZE;\n    if(x>=W){x=0;y+=SIZE}\n  }\n  requestAnimationFrame(loop);\n}\nloop();\n</script>\n\n</body>\n</html>\n",
  "config": {
    "cellSize": { "type": "number", "label": "Cell Size", "default": 22, "min": 8, "max": 50, "step": 1 },
    "lineWidth": { "type": "number", "label": "Line Width", "default": 2, "min": 0.5, "max": 5, "step": 0.5 },
    "color": { "type": "color", "label": "Color", "default": "#c0c0c0" },
    "bgColor": { "type": "color", "label": "Background Color", "default": "#050b07" }
  }
}

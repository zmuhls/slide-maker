{
  "id": "artifact-molnar",
  "name": "Molnar",
  "description": "Geometric compositions inspired by Vera Molnár",
  "source": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<style>.back-btn,#back,#info,#ui,#mode-btn{display:none!important}</style>\n<script>if(window.self===window.top)document.documentElement.classList.add('standalone')</script>\n<style>html.standalone .back-btn,html.standalone #back,html.standalone #info,html.standalone #ui,html.standalone #mode-btn{display:revert!important}</style>\n<meta charset=\"utf-8\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no,viewport-fit=cover\"/>\n<link rel=\"icon\" href=\"data:image/svg+xml;base64,\"/>\n<title>Interruptions — Vera Molnar</title>\n<style>\n*{margin:0;padding:0;box-sizing:border-box}\nhtml,body{height:100%;height:100dvh;background:#0a0a0a;overflow:hidden}\ncanvas{display:block;width:100%;height:100%;touch-action:none}\n#info{position:fixed;bottom:16px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.9);background:rgba(0,0,0,0.6);padding:6px 12px;border-radius:6px;text-shadow:0 1px 3px rgba(0,0,0,0.9);font:13px/1.4 ui-monospace,monospace;pointer-events:none;text-align:center}\n.back-btn{position:fixed;top:max(16px, env(safe-area-inset-top));right:max(16px, env(safe-area-inset-right));background:rgba(20,20,20,0.8);border:1px solid #444;color:#e0e0e0;padding:8px 14px;border-radius:6px;font:12px ui-monospace,monospace;cursor:pointer;text-decoration:none;backdrop-filter:blur(8px);z-index:1000;transition:border-color 0.2s}\n.back-btn:hover{border-color:#888}\n</style>\n</head>\n<body>\n<a href=\"./\" class=\"back-btn\">← Gallery</a>\n<canvas id=\"c\"></canvas>\n<div id=\"info\">Vera Molnar, Interruptions (1968+) · move mouse to disrupt · click to regenerate</div>\n<script>\nvar _raw=document.body.getAttribute('data-config');var cfg={};try{if(_raw)cfg=JSON.parse(_raw)}catch(e){}\nconst c=document.getElementById('c'),ctx=c.getContext('2d');\nlet W,H,mx=-1,my=-1,grid=[];\n\nfunction resize(){\n  W=c.width=innerWidth;H=c.height=innerHeight;\n  generate();\n}\n\nfunction generate(){\n  grid=[];\n  const COLS=cfg.gridCols??24,ROWS=cfg.gridRows??24;\n  const cellW=W/COLS,cellH=H/ROWS;\n  for(let r=0;r<ROWS;r++){\n    for(let cl=0;cl<COLS;cl++){\n      grid.push({\n        x:cl*cellW+cellW/2,\n        y:r*cellH+cellH/2,\n        w:cellW*0.7,\n        h:cellH*0.7,\n        baseAngle:(Math.random()-0.5)*0.15,\n        seed:Math.random()\n      });\n    }\n  }\n}\n\naddEventListener('resize',resize);\nif(window.visualViewport)window.visualViewport.addEventListener('resize',resize);\nwindow.addEventListener('orientationchange',()=>requestAnimationFrame(resize));\nrequestAnimationFrame(()=>{resize();});\naddEventListener('click',generate);\naddEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});\naddEventListener('touchmove',e=>{mx=e.touches[0].clientX;my=e.touches[0].clientY},{passive:true});\n\nfunction loop(){\n  ctx.fillStyle='#0a0a0a';ctx.fillRect(0,0,W,H);\n  ctx.strokeStyle='#c0c0c0';ctx.lineWidth=1;\n\n  const radius=Math.min(W,H)*0.25;\n  for(const g of grid){\n    const dx=mx-g.x,dy=my-g.y;\n    const dist=Math.sqrt(dx*dx+dy*dy);\n    const influence=(cfg.disruption??true)?Math.max(0,1-dist/radius):0;\n    const disruption=influence*influence;\n    const angle=g.baseAngle+disruption*(g.seed-0.5)*Math.PI*1.5;\n    const scale=1-disruption*0.4*g.seed;\n    const ox=disruption*(g.seed-0.5)*12;\n    const oy=disruption*(g.seed-0.5)*12;\n\n    ctx.save();\n    ctx.translate(g.x+ox,g.y+oy);\n    ctx.rotate(angle);\n    ctx.globalAlpha=0.4+0.6*(1-disruption*0.5);\n    ctx.strokeRect(-g.w*scale/2,-g.h*scale/2,g.w*scale,g.h*scale);\n    ctx.restore();\n  }\n  ctx.globalAlpha=1;\n  requestAnimationFrame(loop);\n}\nloop();\n</script>\n\n</body>\n</html>\n",
  "config": {
    "gridCols": { "type": "number", "label": "Grid Columns", "default": 24, "min": 6, "max": 40, "step": 1 },
    "gridRows": { "type": "number", "label": "Grid Rows", "default": 24, "min": 6, "max": 40, "step": 1 },
    "disruption": { "type": "boolean", "label": "Mouse Disruption", "default": true }
  }
}
